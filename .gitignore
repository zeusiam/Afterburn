# macOS
.DS_Store

# Unity — everything regenerable lives under UnityProject/
UnityProject/[Ll]ibrary/
UnityProject/[Tt]emp/
UnityProject/[Oo]bj/
UnityProject/[Bb]uild/
UnityProject/[Bb]uilds/
UnityProject/[Ll]ogs/
UnityProject/[Uu]serSettings/
UnityProject/[Mm]emoryCaptures/
UnityProject/[Rr]ecordings/

# Never ignore the Asset Store tools folder if it appears
!UnityProject/[Aa]ssets/AssetStoreTools*

# Vendor asset packs — re-importable from the Asset Store, too large for GitHub
# (USC contains a 108MB file; GitHub hard-rejects >100MB). Fresh clones: reimport
# these via Package Manager > My Assets, GUIDs are stable so references restore.
#   Ultimate Spaceships Creator · Sci-Fi Modular Weapons · Modular Warp Gates · StarSparrow
UnityProject/Assets/UltimateSpaceshipsCreator/
UnityProject/Assets/UltimateSpaceshipsCreator.meta
UnityProject/Assets/ModularSci-FiWeapons/
UnityProject/Assets/ModularSci-FiWeapons.meta
UnityProject/Assets/WarpGates/
UnityProject/Assets/WarpGates.meta
UnityProject/Assets/StarSparrow/
UnityProject/Assets/StarSparrow.meta

# Autogenerated VS/Rider/VSCode
UnityProject/.vs/
UnityProject/.idea/
UnityProject/.vsconfig
UnityProject/*.csproj
UnityProject/*.sln
UnityProject/*.slnx

# Unity crash reports / profiler
sysinfo.txt
*.stackdump

# Builds & packages
*.apk
*.aab
*.unitypackage
*.app

# Crashlytics
crashlytics-build.properties
