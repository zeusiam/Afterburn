# macOS
.DS_Store

# Unity — everything regenerable lives under UnityProject/
UnityProject/[Ll]ibrary/
UnityProject/[Tt]emp/
UnityProject/[Oo]bj/
UnityProject/[Bb]uild/
UnityProject/[Bb]uilds/
UnityProject/[Ll]ogs/
UnityProject/[Uu]serSettings/
UnityProject/[Mm]emoryCaptures/
UnityProject/[Rr]ecordings/

# Never ignore the Asset Store tools folder if it appears
!UnityProject/[Aa]ssets/AssetStoreTools*

# Autogenerated VS/Rider/VSCode
UnityProject/.vs/
UnityProject/.idea/
UnityProject/.vsconfig
UnityProject/*.csproj
UnityProject/*.sln
UnityProject/*.slnx

# Unity crash reports / profiler
sysinfo.txt
*.stackdump

# Builds & packages
*.apk
*.aab
*.unitypackage
*.app

# Crashlytics
crashlytics-build.properties
